APP_NAME=Git Inference API
API_WAIT_TIMEOUT_SECONDS=180
JOB_TIMEOUT_SECONDS=900
WORKER_POLL_INTERVAL_SECONDS=1
RESULT_POLL_INTERVAL_SECONDS=2
ROUTER_STAGE_TIMEOUT_SECONDS=900
PLANNER_STAGE_TIMEOUT_SECONDS=120
ANSWERER_STAGE_TIMEOUT_SECONDS=180
FINAL_PHRASER_STAGE_TIMEOUT_SECONDS=120
DB_PATH=/tmp/git_inference_api/jobs.db
REPO_PATH=/tmp/git_inference_api/workrepo
REPO_BRANCH=main
REQUESTS_DIR=requests
RESPONSES_DIR=responses
ERRORS_DIR=errors
COMBINED_DIR=combined
GIT_AUTHOR_NAME=Git Inference API
GIT_AUTHOR_EMAIL=git-inference-api@example.com
AUTO_INIT_REPO=false
AVAILABLE_MODELS=git-chatgpt-json,git-chatgpt,git-perplexity,git-grok
OPENCLAW_COMPAT_MODELS=git-chatgpt,git-perplexity,git-grok
ALL_SEQUENTIAL_MODELS=git-perplexity,git-grok,git-inceptionlabs,git-qwen
ALLSEQUENTIAL_VIRTUAL_TURNS_ENABLED=false
ALLSEQUENTIAL_VIRTUAL_TURNS_SEND_FAILURES=true
PROMPT_CHUNK_WORDS=2000
PROMPT_MAX_CHUNKS=5
STALE_INFLIGHT_MAX_AGE_SECONDS=900
ADMIN_API_KEY=
ENABLE_STALE_GIT_LOCK_CLEANUP=true
GIT_LOCK_STALE_SECONDS=120
ENABLE_STAGE_ORCHESTRATION=false
ENABLE_RUNTIME_HANDOFF_EXECUTOR=false
OPENCLAW_CRON_SSH_TARGET=
OPENCLAW_CRON_CLI_PATH=~/.npm-global/bin/openclaw
OPENCLAW_CRON_AGENT=main
OPENCLAW_CRON_CHANNEL=telegram
OPENCLAW_CRON_TO=
OPENCLAW_CRON_TIMEOUT_SECONDS=120
OPENCLAW_CRON_WINDOWS_SSH_PATH=/mnt/c/Windows/System32/OpenSSH/ssh.exe
